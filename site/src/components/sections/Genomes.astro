---
import genomes from '../../data/genomes.json';
const items = [...genomes.items].sort((a, b) => b.year - a.year);
---

<section class="section" id="publications">
  <div class="container">
    <p class="section__eyebrow" data-reveal>Publications</p>
    <h2 class="section__title" data-reveal>{genomes.title}</h2>
    <p class="section__lede" data-reveal>{genomes.lede}</p>

    <ul class="gen__grid">
      {
        items.map((g) => (
          <a class="card gen" href={g.url} target="_blank" rel="noopener" data-reveal>
            <div class="gen__top">
              <h3 class="gen__name">{g.name}</h3>
              <span class="gen__year">{g.year}</span>
            </div>
            <p class="gen__acc">
              GenBank <span class="gen__acc-id">{g.accession}</span>
            </p>
          </a>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .gen__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--sp-2); list-style: none; padding: 0; margin: 0; }
  .gen__top { display: flex; align-items: baseline; justify-content: space-between; gap: var(--sp-2); }
  .gen__name { font-size: var(--fs-2); font-family: var(--font-mono); letter-spacing: 0.01em; }
  .gen__year { color: var(--fg-faint); font-size: var(--fs-1); font-variant-numeric: tabular-nums; }
  .gen__acc { color: var(--fg-soft); font-size: var(--fs-1); margin: var(--sp-1) 0 0; }
  .gen__acc-id { color: var(--accent); }
  @media (max-width: 720px) {
    .gen__grid { grid-template-columns: 1fr; }
  }
</style>
