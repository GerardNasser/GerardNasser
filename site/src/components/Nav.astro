---
import { nav, site } from '../data/site';
---

<header class="nav" data-nav>
  <div class="container nav__inner">
    <a class="nav__brand" href="#top">
      <span class="nav__dot" aria-hidden="true"></span>
      {site.name}
    </a>
    <nav aria-label="Sections">
      <ul class="nav__list">
        {
          nav.map((item) => (
            <li>
              <a href={`#${item.id}`}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
  <div class="nav__progress" aria-hidden="true"><span data-nav-progress></span></div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s var(--ease-out), background 0.3s var(--ease-out);
  }
  .nav[data-scrolled] {
    border-bottom-color: var(--border);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    gap: var(--sp-3);
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    color: var(--fg);
    font-weight: 700;
    font-size: var(--fs-1);
    letter-spacing: 0.02em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .nav__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--glow-accent);
  }
  .nav__list {
    list-style: none;
    display: flex;
    gap: var(--sp-3);
    margin: 0;
    padding: 0;
    font-size: var(--fs-1);
  }
  .nav__list a {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding-inline: 6px;
    color: var(--fg-soft);
  }
  /* active-section underline: a short accent rule that fades in */
  .nav__list a::after {
    content: '';
    position: absolute;
    left: 6px;
    right: 6px;
    bottom: 12px;
    height: 1.5px;
    background: var(--accent);
    box-shadow: 0 0 8px var(--glow-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.28s var(--ease-out);
  }
  .nav__list a:hover,
  .nav__list a[aria-current='true'] {
    color: var(--fg);
  }
  .nav__list a[aria-current='true']::after { transform: scaleX(1); }

  /* scroll-progress rail pinned to the bottom edge of the bar */
  .nav__progress {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: transparent;
  }
  .nav__progress span {
    display: block;
    height: 100%;
    width: var(--progress, 0%);
    background: linear-gradient(90deg, var(--nt-a), var(--nt-c));
    box-shadow: 0 0 10px var(--glow-accent);
    transition: width 0.1s linear;
  }
  /* On small screens the section links scroll horizontally rather than wrap/crowd */
  @media (max-width: 720px) {
    .nav__list {
      gap: var(--sp-2);
      font-size: var(--fs-0);
      overflow-x: auto;
      max-width: 62vw;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .nav__list::-webkit-scrollbar { display: none; }
  }
</style>
